[Unit]
Description=Iron Lady Assistant Codex OpenAI Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=claude-developer
WorkingDirectory=/home/claude-developer/iron-lady-assistant
ExecStart=/home/claude-developer/iron-lady-assistant/venv/bin/python3 -m src.codex_proxy
Restart=always
RestartSec=5
EnvironmentFile=/home/claude-developer/iron-lady-assistant/.env
Environment=PATH=/home/claude-developer/.npm-claude-developer/bin:/home/claude-developer/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/claude-developer/iron-lady-assistant/work-dir
PrivateTmp=true

[Install]
WantedBy=multi-user.target
