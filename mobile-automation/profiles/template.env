# Copy this file and customize for your app.

# Android SDK / AVD
ANDROID_SDK_ROOT="$HOME/android-sdk"
ANDROID_HOME="$ANDROID_SDK_ROOT"
ANDROID_AVD_HOME="$HOME/.android/avd"
ANDROID_API_LEVEL="35"
ANDROID_SYSTEM_IMAGE_FLAVOR="google_apis"
ANDROID_ARCH="x86_64"
ANDROID_DEVICE_PROFILE="pixel_7"
AVD_NAME="mobile_api35"
ANDROID_EMULATOR_SERIAL="emulator-5554"
ANDROID_EMULATOR_HEADLESS="1"
ANDROID_EMULATOR_MEMORY_MB="4096"

# Appium
APPIUM_HOST="127.0.0.1"
APPIUM_PORT="4723"
APPIUM_URL="http://127.0.0.1:4723"
NO_RESET="true"
NEW_COMMAND_TIMEOUT="300"
ANDROID_PLATFORM_NAME="Android"
ANDROID_DEVICE_NAME="emulator-5554"
ANDROID_PLATFORM_VERSION=""

# Target app
APP_NAME="ExampleApp"
APP_PACKAGE="com.example.app"
APP_ACTIVITY=".MainActivity"
# Optional: path to local APK for adb install -r
APK_PATH=""

# Artifacts
OUT_DIR="mobile-automation/artifacts"
